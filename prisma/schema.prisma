// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String    @id @default(uuid())
  username String    @unique
  password String    // Zahashowane hasło bcrypt
  currency String    @default("PLN") // Miejsce na przyszłą obsługę walut
  savings  Float     @default(0.0)
  
  // Relacje
  expenses   Expense[]
  incomes    Income[]   // Relacja do dynamicznych wpływów (wypłat)
  categories Category[] // Relacja do kategorii (każdy ma swoje)
}

// Tabela na wpływy (wypłaty, premie, zwroty), dodawane co miesiąc
model Income {
  id          String   @id @default(uuid())
  amount      Float
  source      String?  // np. "Wypłata z etatu", "Przelew od babci"
  date        DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Category {
  id       String    @id @default(uuid())
  name     String
  icon     String?   // Nazwa ikony (np. z Lucide), do edycji pod "zębatką"
  
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  expenses Expense[]
}

model Expense {
  id          String   @id @default(uuid())
  amount      Float
  description String?
  date        DateTime
  isRecurring Boolean  @default(false) // Czy to płatność cykliczna
  type        String   @default("EXPENSE") // Opcje: EXPENSE, INVESTMENT, SAVING
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId  String?  // Opcjonalne (np. transfer na oszczędności może nie mieć kategorii)
  category    Category? @relation(fields: [categoryId], references: [id])
  
  createdAt   DateTime @default(now())
}