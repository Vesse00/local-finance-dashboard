// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String    @id @default(uuid())
  username String    @unique
  email    String    @unique
  password String    // Zahashowane hasło bcrypt
  currency String    @default("PLN") // Miejsce na przyszłą obsługę walut
  savings  Float     @default(0.0)
  payday   Int       @default(10)    // Dzień miesiąca, w którym użytkownik otrzymuje wypłatę

  location         String?

  // POLA DO ODZYSKIWANIA HASŁA E-MAILEM
  resetToken       String?  @unique
  resetTokenExpiry DateTime?
  
  // Relacje
  recurringPayments RecurringPayment[]
  expenses   Expense[]
  incomes    Income[]   // Relacja do dynamicznych wpływów (wypłat)
  categories Category[] // Relacja do kategorii (każdy ma swoje)
  monthSummaries MonthSummary[] // Relacja do miesięcznych podsumowań
  workDays   WorkDay[] // Relacja do dni pracy i nadgodzin
  healthDays  HealthDay[] // Relacja do logów zdrowotnych
  healthEntries HealthEntry[] // Relacja do pojedynczych posiłków i treningów
  drawerItems DrawerItem[] // Relacja do cyfrowej szuflady
  cars         Car[]        // Relacja do Garażu
  savingsAccounts SavingsAccount[] // Relacja do kont oszczędnościowych
  savingsTransactions SavingsTransaction[] // Relacja do transakcji na kontach oszczędnościowych
  energyEntries   EnergyEntry[] // Relacja do logów  nastrójów
  customProducts CustomProduct[] // Relacja do własnych posiłków
}

// Tabela na wpływy
model Income {
  id                  String   @id @default(uuid())
  amount              Float
  currency            String   @default("PLN") // NOWE: Waluta
  source              String?  
  description         String?  
  bankTransactionType String?  
  date                DateTime @default(now())
  
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())

  // INDEKSY OPTYMALIZACYJNE:
  @@index([userId, date])
}

// Tabela na wydatki i transfery
model Expense {
  id                  String   @id @default(uuid())
  amount              Float
  currency            String   @default("PLN") // NOWE: Waluta
  description         String?  
  recipient           String?  
  bankTransactionType String?  
  date                DateTime
  isRecurring         Boolean  @default(false)
  type                String   @default("EXPENSE") 
  
  status              String   @default("COMPLETED") // NOWE: "COMPLETED" (Zapłacone) lub "PENDING" (Oczekujące/Czerwone)
  
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId          String?
  category            Category? @relation(fields: [categoryId], references: [id])

  // Relacja z zleceniem stałym
  recurringId         String?
  recurring           RecurringPayment? @relation(fields: [recurringId], references: [id], onDelete: Cascade)

  // Deduplication przy imporcie: hash z (data+kwota+iban_odbiorcy+userId)
  bankTxHash          String?  @unique
  
  createdAt           DateTime @default(now())

  // INDEKSY OPTYMALIZACYJNE:
  @@index([userId, date])
  @@index([categoryId])
}

// NOWOŚĆ: Zlecenia stałe, subskrypcje i raty kredytowe
model RecurringPayment {
  id              String   @id @default(uuid())
  name            String   // np. "Rata za samochód", "Internet"
  defaultAmount   Float    // Domyślna kwota do zapłaty
  currency        String   @default("PLN")
  dayOfMonth      Int      // Dzień płatności (1-31)
  
  // Pola dla kredytów/rat (opcjonalne)
  totalAmount     Float?   // Kwota całkowita do spłaty (np. 100 000)
  remainingAmount Float?   // Ile jeszcze zostało (zmienia się przy nadpłatach)

  endDate         DateTime? // Kiedy kończy się subskrypcja lub kredyt (null = bezterminowo)
  
  isActive        Boolean  @default(true) // Czy zlecenie jest nadal aktywne?

  // Dopasowanie do transakcji przy imporcie bankowym
  recipientAccountNo  String?  // IBAN odbiorcy np. "82160014621815538750000002"
  matchPhrase         String?  // Fallback: fraza w opisie/odbiorcy (dla płatności kartą bez IBAN)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  
  // Lista opłaconych już rat wygenerowanych z tego zlecenia
  expenses        Expense[] 
  
  createdAt       DateTime @default(now())
}

// Model Category pozostaje bez zmian (upewnij się tylko, że nie ma błędów)
model Category {
  id          String    @id @default(uuid())
  name        String
  icon        String
  budgetLimit Float?    // NOWOŚĆ: Opcjonalny miesięczny limit przydzielony na wydatki w tej kategorii
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  recurrings  RecurringPayment[] // Relacja wsteczna
}

model MonthSummary {
  id              String   @id @default(uuid())
  monthYear       String   // np. "02-2026"
  savingsTotal    Float    // Całkowite oszczędności na koniec miesiąca
  leftToSpend     Float    // Ile zostało "Kwoty wolnej" (nadwyżka/niedobór)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())

  @@unique([userId, monthYear]) // Zapewnia, że nie zdublujemy podsumowania dla tego samego miesiąca
}

// NOWOŚĆ: Model do śledzenia czasu pracy, zmian i nadgodzin
model WorkDay {
  id          String   @id @default(uuid())
  date        DateTime // Konkretny dzień w kalendarzu
  
  // Klasyczne godziny zmiany, np. "13:45" i "21:45"
  startTime   String?
  endTime     String?
  
  // Informacje o nadgodzinach
  isOvertime  Boolean  @default(false) // Czy tego dnia były nadgodziny?
  overtimeHours Float  @default(0)     // Ile godzin dodatkowych (np. 4.5)
  
  shiftType   String   @default("REGULAR") // "REGULAR", "OVERTIME_ONLY" (np. sobota)
  notes       String?  // Opcjonalne notatki do dnia
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date]) // Zabezpieczenie, by w jeden dzień był tylko jeden wpis dla danego usera
}

//  Model do śledzenia zdrowia (Waga, Woda, Treningi, Kalorie)
model HealthDay {
  id           String   @id @default(uuid())
  date         DateTime
  
  weight       Float?   // Waga w kg (np. 82.5)
  waterGlasses Int      @default(0) // Ilość wypitych szklanek/butelek
  calories     Int?     // Spożyte kalorie
  workout      String?  // Notatka o treningu (np. "Siłownia - Klatka", "Bieganie 5km")

  // Wymiary (w cm)
  chest        Float?   // Klatka piersiowa
  waist        Float?   // Pas / Talia
  hips         Float?   // Biodra
  biceps       Float?   // Ramię / Biceps
  thigh        Float?   // Udo
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date]) // Jeden wpis zdrowotny na jeden konkretny dzień
}

// Model do śledzenia pojedynczych treningów i posiłków
model HealthEntry {
  id          String   @id @default(uuid())
  date        DateTime
  
  type        String   // "WORKOUT" lub "CALORIES"
  title       String   // Nazwa (np. "Siłownia", "Śniadanie")
  calories    Int      @default(0) // Ilość kalorii (tylko dla typu CALORIES)
  detasils     String?  // Pole na szczegóły ćwiczeń (zapisane jako JSON)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model CustomProduct {
  id          String   @id @default(uuid())
  name        String
  kcal        Float
  proteins    Float
  carbs       Float
  fats        Float
  
  isRecipe    Boolean  @default(false)
  ingredients String?  // (JSON) Zapisane składniki własnego dania

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

// Cyfrowa Szuflada (Umowy, Gwarancje, Subskrypcje)
model DrawerItem {
  id           String   @id @default(uuid())
  title        String   // np. "Umowa Wynajmu Mieszkania", "Telewizor Samsung"
  type         String   // "CONTRACT" (Umowa) lub "WARRANTY" (Gwarancja)
  
  startDate    DateTime // Data zawarcia umowy / zakupu
  endDate      DateTime? // Data końca umowy / gwarancji
  
  cost         Float?   // Koszt
  isRecurring  Boolean  @default(false) // Czy to płatność cykliczna (abonament/rata)
  
  documentUrl  String?  // Opcjonalny link do pliku na dysku/chmurze
  notes        String?  

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
}

// ==========================================
// MODUŁ GARAŻ (Zarządzanie samochodami)
// ==========================================

model Car {
  id           String     @id @default(uuid())
  make         String     // Marka (np. Toyota)
  model        String     // Model (np. Yaris)
  plate        String?    // Numer rejestracyjny
  year         Int?       // Rok produkcji
  
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  events       CarEvent[] // Historia serwisowa i opłaty
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CarEvent {
  id           String   @id @default(uuid())
  type         String   // "INSURANCE" (OC/AC), "INSPECTION" (Przegląd), "OIL" (Olej), "REPAIR" (Naprawa)
  date         DateTime // Data wykonania
  nextDueDate  DateTime? // Kiedy następny raz? (Ważność OC / Kolejny przegląd)
  nextDueMileage Int?      // NOWOŚĆ: Limit kilometrów na kolejny serwis
  
  cost         Float?   // Koszt usługi
  description  String?  // Opis (np. "Wymiana klocków przód")

  
  mileage      Int?     // Stan licznika (przebieg)
  liters       Float?   // Ilość zatankowanego paliwa (L)
  pricePerLiter Float?  // Cena za litr (PLN)
  
  carId        String
  car          Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
}

// ==========================================
// MODUŁ OSZCZĘDNOŚCI (IKE, IKZE, Konta)
// ==========================================

model SavingsAccount {
  id        String   @id @default(uuid())
  name      String   // np. "Poduszka finansowa", "IKE mBank"
  balance   Float    @default(0.0)
  type      String   @default("SAVINGS") // "SAVINGS", "IKE", "IKZE"
  currency  String   @default("PLN")    // np. "PLN", "EUR", "USD"

  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions SavingsTransaction[] // Relacja do transakcji na tym koncie
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavingsTransaction {
  id               String   @id @default(uuid())
  amount           Float
  type             String   // "IN" (Wpłata) lub "OUT" (Wypłata)
  description      String?
  date             DateTime @default(now())

  // Jeśli ID konta jest puste (null), oznacza to, że transakcja dotyczy "Głównych Oszczędności"
  savingsAccountId String?
  savingsAccount   SavingsAccount? @relation(fields: [savingsAccountId], references: [id], onDelete: Cascade)

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EnergyEntry {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime // Zwykłe DateTime, bez @db.Date!
  overallScore  Int      // Skala 0-100%
  workScore     Int?     // Opcjonalne 0-100%
  freeTimeScore Int?     // Opcjonalne 0-100%
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date]) // Zabezpieczenie: tylko 1 główny wpis na dzień
}